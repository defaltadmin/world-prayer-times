/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), notifications=(self)
  Cross-Origin-Opener-Policy: same-origin
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com https://prayer.mscarabia.com/cdn-cgi/zaraz; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.aladhan.com https://nominatim.openstreetmap.org https://www.google-analytics.com https://cloudflareinsights.com https://prayer.mscarabia.com/cdn-cgi/rum https://prayer.mscarabia.com/cdn-cgi/zaraz; img-src 'self' data: blob:; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;
  Cache-Control: no-cache, must-revalidate
